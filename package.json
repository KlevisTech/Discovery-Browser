{
  "name": "discovery-browser",
  "version": "3.0.1",
  "description": "A beautiful, unique card-style web browser built with Electron",
  "author": "Modern Tech",
  "license": "Apache-2.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:auth": "dotnet publish webview2-auth/Discovery.YouTubeAuth.csproj -c Release -r win-x64 --self-contained false -o webview2-auth/publish",
    "prebuild": "npm run build:auth",
    "prebuild:win": "npm run build:auth"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.discovery.browser",
    "productName": "Discovery Browser",
    "files": [
      "main.js",
      "preload.js",
      "preload-card.js",
      "preload-visualizer-widget.js",
      "preload-card-bubble.js",
      "preload-card-overlay.js",
      "preload-webview.js",
      "preload-readmode.js",
      "preload-media-player.js",
      "preload-recap.js",
      "preload-media-progress-widget.js",
      "preload-side-flames-widget.js",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "installer.nsh",
      "google-webview2-auth.js",
      "google-auth-url-classifier.js"
    ],
    "protocols": [
      {
        "name": "HTTP",
        "schemes": [
          "http"
        ],
        "role": "Viewer"
      },
      {
        "name": "HTTPS",
        "schemes": [
          "https"
        ],
        "role": "Viewer"
      }
    ],
    "win": {
      "icon": "assets/discoverybrowser.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Modern Tech",
      "fileAssociations": [
        {
          "ext": "html",
          "name": "HTML Document",
          "description": "HTML Document",
          "role": "Viewer"
        },
        {
          "ext": "htm",
          "name": "HTM Document",
          "description": "HTM Document",
          "role": "Viewer"
        }
      ],
      "extraResources": [
        {
          "from": "webview2-auth/publish",
          "to": "webview2-auth",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "assets/discoverybrowser.ico",
      "uninstallerIcon": "assets/discoverybrowser.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Discovery Browser",
      "perMachine": true,
      "allowElevation": true,
      "runAfterFinish": true,
      "include": "installer.nsh"
    }
  }
}
